# --- DEPENDENCIES & BUILD ARTIFACTS ---
# Exclude Node dependencies in ALL subfolders (Crucial)
**/node_modules

# Exclude build/dist folders that get created during compilation
dist
build
/coverage

# --- SENSITIVE DATA (CRITICAL) ---
# Exclude ALL .env files and deployment environment files
# This prevents accidentally committing API keys, secrets, or DB credentials.
**/.env
.env.*
env.deployment
*.env
*.template